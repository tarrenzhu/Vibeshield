# ============================================
# VibeShield — Environment Variables Template
# Copy to .env and fill in your values
# ============================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# DeepSeek API (AI model)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Trigger.dev (background jobs)
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxxxxxx

# Supabase (database)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx

# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# GitHub App (pending domain — leave empty for now)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Sentry (error monitoring)
SENTRY_DSN=https://xxxxxxxxxxxx@sentry.io/123456

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
